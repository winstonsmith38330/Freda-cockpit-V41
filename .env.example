# Freda Ops Cockpit Beta 0.2.40 - Render Environment
# Paste into Render > Environment > Add from .env
# Do NOT upload this file to GitHub.

NODE_VERSION=20.19.0
NODE_ENV=production
PORT=8787
TIMEZONE=Australia/Sydney
DEFAULT_REPORTING_DATE_MODE=today

# Replace with your actual Render service URL
ALLOWED_ORIGINS=https://YOUR-RENDER-SERVICE.onrender.com
APP_PUBLIC_URL=https://YOUR-RENDER-SERVICE.onrender.com

# Storage / imports
SEED_DATA_PATH=../seed-data.json
LIVE_DATA_PATH=./data/live-snapshots.json
IMPORTS_PATH=./data/imports
ENABLE_FILE_IMPORTS=true
IMPORT_PARSE_TICKET_HISTORY=false

# POS source policy
# POS daily/hourly/product data comes from reporting.site live sync first.
# Uploaded POS Excel/CSV files are backup only.
POS_SOURCE_POLICY=sync_first_file_backup
POS_EXCEL_BACKUP_ONLY=true
ENABLE_LIVE_CONNECTORS=false
ENABLE_LIVE_FALLBACK=true
LIVE_FALLBACK_SOURCES=pos
LIVE_FALLBACK_DAYS=10
BENCHMARK_SYNC_WEEKS=4
LIVE_SOURCE_TIMEOUT_MS=18000
RECENT_WINDOW_PER_DATE_TIMEOUT_MS=18000
IMPORT_SYNC_TIMEOUT_MS=18000

# Forced browser diagnostics for reporting.site ECONNRESET / LiteSpeed resets
ENABLE_BROWSER_SYNC=true
REPORTING_FORCE_BROWSER_SYNC=true
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSERS_PATH=0
BROWSER_SYNC_TIMEOUT_MS=45000
REPORTING_REQUEST_DELAY_MS=2500
REPORTING_BROWSER_VIEWS=busy_hours.php,product_sales_summary.php,product_sales.php,daily_sales.php

# POS / reporting.site
REPORTING_BASE_URL=https://reporting.site
REPORTING_TIMEZONE_OFFSET=+10:00
REPORTING_COOKIE=PASTE_FULL_REPORTING_COOKIE_HEADER_HERE
REPORTING_PHPSESSID=PASTE_PHPSESSID_ONLY_HERE
REPORTING_EMAIL=
REPORTING_PASSWORD=
REPORTING_STORE_BEVERLY_HILLS=ladonuts_beverlyhills
REPORTING_STORE_PENRITH=ladonuts_penrith
REPORTING_STORE_TAREN_POINT=ladonuts_tarenpoint
REPORTING_STORE_ALLVENUES=ladonuts_allvenues
REPORTING_POS_BEVERLY_HILLS_BASE=https://reporting.site/ladonuts_beverlyhills/dashboard
REPORTING_POS_PENRITH_BASE=https://reporting.site/ladonuts_penrith/dashboard
REPORTING_POS_TAREN_POINT_BASE=https://reporting.site/ladonuts_tarenpoint/dashboard
REPORTING_POS_ALLVENUES_BASE=https://reporting.site/ladonuts_allvenues/dashboard
REPORTING_VIEWS=busy_hours.php,product_sales_summary.php,product_sales.php,dashboard.php,eod_summary.php,daily_sales.php
REPORTING_ALLOW_UNDATED_RECENT_SCRAPE=true
REPORTING_DISABLE_TICKET_ENRICHMENT=true
REPORTING_MAX_DATE_ATTEMPTS=5
REPORTING_SYNC_TIMEOUT_MS=45000
POS_DAY_TIMEOUT_MS=45000
REPORTING_BUSY_HOURS_METHOD=POST_DATE_RANGE
POS_BENCHMARK_SYNC=true
REPORTING_FETCH_RETRIES=1

# Uber: imported from workbook by default; keep cookie if explicit Uber sync is tested later
UBER_COOKIE=PASTE_FRESH_FULL_UBER_COOKIE_IN_RENDER_ONLY
UBER_MANAGER_BASE_URL=https://merchants.ubereats.com/manager/home/503ef13c-4f47-4581-acdf-2179564db004
UBER_TIMEZONE_OFFSET=+10:00
UBER_STORE_BEVERLY_HILLS=503ef13c-4f47-4581-acdf-2179564db004
UBER_STORE_PENRITH=503ef13c-4f47-4581-acdf-2179564db004
UBER_STORE_TAREN_POINT=503ef13c-4f47-4581-acdf-2179564db004
UBER_STORE_NAME_BEVERLY_HILLS=L.A Donut
UBER_STORE_NAME_PENRITH=L.A DONUTS (Penrith)
UBER_STORE_NAME_TAREN_POINT=L.A DONUTS Taren Point

# Square/Frieda: imported from June item CSV by default
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=production
SQUARE_TIMEZONE_OFFSET=+10:00

# Optional AI/email/future integrations
OPENAI_API_KEY=PASTE_OPENAI_API_KEY_IN_RENDER_ONLY
OPENAI_MODEL=gpt-5.5
SENDGRID_API_KEY=
ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_API_KEY=
DEPUTY_API_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
